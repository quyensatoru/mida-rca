PORT=7400
ANTHROPIC_API_KEY=<your-anthropic-api-key>
MCP_DIAGNOSTIC_URL=http://localhost:7401/mcp
MCP_OPS_TOKEN=<shared-secret-with-mcp-diagnostic>
OPS_MONGO_URI=<mongodb-uri-for-ops-db>
MATTERMOST_WEBHOOK_SECRET=<mattermost-webhook-secret>
MATTERMOST_URL=https://<mattermost-host>
MATTERMOST_BOT_TOKEN=<bot-token-for-posting-replies>

# Executor (Phase 4 — WRITE plane, gated by human approval)
EXECUTOR_REPOS_ROOT=/srv/repos
EXECUTOR_ALLOWED_REPOS=sama-api
EXECUTOR_TARGET_BRANCH=develop
BITBUCKET_API_URL=https://<bitbucket-host>
BITBUCKET_ACCESS_TOKEN=<read-write token for PR creation only>
BITBUCKET_PROJECT=<project key>
