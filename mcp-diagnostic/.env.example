PORT=7401
MCP_OPS_TOKEN=<shared secret with orchestrator>

# Sentry
SENTRY_API_TOKEN=<auth token read-only, scope: project:read, event:read>
SENTRY_ORG=<org slug>
SENTRY_BASE_URL=https://sentry.io/api/0

# Docker Swarm (read logs) — run on manager node or via docker socket
DOCKER_BIN=docker

# Jenkins
JENKINS_URL=https://<jenkins-host>
JENKINS_USER=<user>
JENKINS_TOKEN=<api token read-only>

# Git repos (read-only clones of sama-* repos for commit history)
REPOS_ROOT=/srv/repos

# MongoDB — Phase 5
PROXY_URI=mongodb://readonly:<pass>@<proxy-host>/proxy     # tenant→shard resolver (shops collection)
API_URI_1=mongodb://readonly:<pass>@<shard1-host>/sama     # shard 1 events + db_query
API_URI_2=mongodb://readonly:<pass>@<shard2-host>/sama     # shard 2 (if any Mongo)

# ClickHouse — Phase 5
CH_URI=http://readonly:<pass>@<ch-host>:8123               # read-only ClickHouse user

# RabbitMQ management API — Phase 5
RABBITMQ_MGMT_URL=http://<rabbitmq-host>:15672
RABBITMQ_USER=<management user>
RABBITMQ_PASS=<management password>

# Redis — Phase 5
REDIS_URL=redis://<redis-host>:6379                        # app Redis (cache_status tool)

# Cache Redis — Phase 5 (optional; can be same as REDIS_URL or a separate instance)
CACHE_REDIS_URL=redis://<redis-host>:6379                  # RCA result cache (60s TTL)
